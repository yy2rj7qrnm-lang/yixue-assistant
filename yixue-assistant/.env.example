# 数据库配置
DATABASE_URL="mysql://username:password@localhost:3306/yixue_assistant"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# 服务配置
NODE_ENV="development"
PORT="8000"
CLIENT_URL="http://localhost:3000"

# OCR服务配置
BAIDU_OCR_APP_ID="your-baidu-ocr-app-id"
BAIDU_OCR_API_KEY="your-baidu-ocr-api-key"
BAIDU_OCR_SECRET_KEY="your-baidu-ocr-secret-key"

TENCENT_OCR_SECRET_ID="your-tencent-ocr-secret-id"
TENCENT_OCR_SECRET_KEY="your-tencent-ocr-secret-key"

# Redis配置
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# 文件上传配置
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE="10485760" # 10MB

# 邮件配置
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# 日志级别
LOG_LEVEL="info"