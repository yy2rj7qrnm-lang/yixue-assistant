generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?
  name        String
  password    String
  avatar      String?
  grade       String?
  subject     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?

  mistakes         Mistake[]
  reports          Report[]
  recommendations  Recommendation[]
  statistics       Statistics[]
  questionAttempts QuestionAttempt[]
  knowledgePoints  KnowledgePoint[]
  reviews          Review[]

  @@map("users")
}

model Mistake {
  id              String   @id @default(cuid())
  userId          String
  subject         String
  grade           String
  chapter         String
  difficulty      String
  questionType    String
  questionImage   String
  questionText    String?
  answer          String
  correctAnswer   String
  analysis        String?
  knowledgePoints String
  mistakeType     String
  isSolved        Boolean  @default(false)
  solvedAt        DateTime?
  reviewCount     Int      @default(0)
  lastReviewAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@map("mistakes")
}

model Review {
  id         String   @id @default(cuid())
  mistakeId  String
  userId     String
  reviewTime DateTime @default(now())
  mastery    Int
  notes      String?

  mistake Mistake @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model KnowledgePoint {
  id           String   @id @default(cuid())
  userId       String
  name         String
  subject      String
  grade        String
  chapter      String
  description  String?
  masteryLevel Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("knowledge_points")
}

model Report {
  id                   String   @id @default(cuid())
  userId               String
  reportType           String
  period               String
  totalMistakes        Int
  solvedMistakes       Int
  correctRate          Float
  knowledgePoints      String
  studyTime            Int
  averageDailyStudyTime Float
  streakDays           Int
  createdAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model Recommendation {
  id          String    @id @default(cuid())
  userId      String
  type        String
  targetId    String
  priority    Int
  reason      String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

model Statistics {
  id                      String   @id @default(cuid())
  userId                  String
  totalQuestions          Int
  totalMistakes           Int
  solvedMistakes          Int
  correctRate             Float
  averageTimePerQuestion  Float
  studyStreak             Int
  weeklyStudyHours        Float
  subjectDistribution     String
  difficultyDistribution  String
  recentProgress          String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("statistics")
}

model Question {
  id              String            @id @default(cuid())
  subject         String
  grade           String
  chapter         String
  difficulty      String
  questionType    String
  content         String
  options         String?
  correctAnswer   String
  analysis        String
  knowledgePoints String
  tags            String
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  attempts QuestionAttempt[]

  @@map("questions")
}

model QuestionAttempt {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  answer     String
  isCorrect  Boolean
  timeSpent  Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_attempts")
}
